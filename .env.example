# Mock mode switch. Defaults to Mock; set to false to call the Spring Boot BFF.
VITE_USE_MOCK=true

# Spring Boot BFF config. Used when VITE_USE_MOCK=false.
VITE_API_BASE_URL=http://localhost:8080
VITE_CHAT_PATH=/api/v1/chat

# Real AI Gateway config. Reserved for server-side use or later real Agent integration.
AI_GATEWAY_API_KEY=

# GitHub OAuth credentials. Optional.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SESSION_SECRET=

# Database config. Defaults to local SQLite; use Turso in production.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
